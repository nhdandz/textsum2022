# ==================== Network Configuration ====================
# Host IP - Change this to your machine's IP address
# For localhost use: 127.0.0.1
# For network access use your machine IP: e.g., 192.168.1.100
HOST_IP=192.168.213.13
BACKEND_API_URL=http://192.168.213.13:8000/api/result
# ==================== Ollama Configuration ====================
OLLAMA_URL=http://192.168.213.13:11434
OLLAMA_MODEL=qwen3:14b

# ==================== Kafka Configuration ====================
